linters: linters_with_defaults(
    object_name_linter(regexes = c(snake_case = "^[a-z][a-z0-9_.]*$", upper_case = "^[A-Z][A-Z0-9_]*$")),
    assignment_linter(),
    line_length_linter(120L),
    indentation_linter(indent = 4L),
    commas_linter(),
    infix_spaces_linter(),
    spaces_inside_linter(),
    brace_linter(),
    pipe_continuation_linter(),
    pipe_consistency_linter(pipe = "|>"),
    quotes_linter(),
    semicolon_linter(allow_compound = FALSE),
    trailing_whitespace_linter(),
    vector_logic_linter(),
    function_return_linter(),
    implicit_assignment_linter(),
    T_and_F_symbol_linter(),
    object_usage_linter = NULL,
    commented_code_linter = NULL,
    return_linter = NULL
  )
encoding: "UTF-8"
exclude: "# nolint"
exclude_start: "# nolint start"
exclude_end: "# nolint end"
