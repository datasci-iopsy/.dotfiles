{
  "model": "opusplan",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read",
      "Read(/var/folders/*/*/T/coderabbit-instructions-*.txt)",
      "WebFetch(domain:docs.coderabbit.ai)",
      "WebSearch",
      "Bash(git:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(cat:*)",
      "Bash(wc:*)",
      "Bash(diff:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(file:*)",
      "Bash(which:*)",
      "Bash(date:*)",
      "Bash(make:*)",
      "Bash(gh:*)",
      "Bash(jq:*)",
      "Bash(duckdb:*)",
      "Bash(textutil:*)",
      "Bash(gcloud config get-value *)",
      "Bash(gcloud projects describe *)",
      "Bash(gcloud auth list)",
      "Bash(graphify:*)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/maintenance-check.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/post-edit-lint.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // empty'); case \"$FILE\" in *.lock|*.env|*.env.*|*credentials*|*secret*|*.pem|*.key) echo 'BLOCK: Refusing write to sensitive file: '\"$FILE\"; exit 2;; esac; exit 0"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CMD=$(jq -r '.tool_input.command // empty'); if echo \"$CMD\" | grep -qE '(python|python3)' && echo \"$CMD\" | grep -qE '(import json|json\\.loads|json\\.dumps)'; then echo 'Prefer jq over Python for JSON parsing -- jq is pre-approved, streaming, and faster for shell tasks.' >&2; exit 1; fi; exit 0"
          }
        ]
      },
      {
        "matcher": "Agent|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/cost-guard.sh"
          }
        ]
      }
    ]
  },
  "env": {},
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
  "effortLevel": "medium",
  "includeGitInstructions": false
}
