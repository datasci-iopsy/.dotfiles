{
    "env": {
        "GIT_AUTHOR_NAME": "datasci-iopsy",
        "GIT_COMMITTER_NAME": "datasci-iopsy"
    },
    "attribution": {
        "commit": "",
        "pr": ""
    },
    "includeGitInstructions": false,
    "permissions": {
        "allow": [
            "Read",
            "WebSearch",
            "Bash(git:*)",
            "Bash(python:*)",
            "Bash(python3:*)",
            "Bash(ls:*)",
            "Bash(cd:*)",
            "Bash(tree:*)",
            "Bash(wc:*)",
            "Bash(diff:*)",
            "Bash(sort:*)",
            "Bash(uniq:*)",
            "Bash(cut:*)",
            "Bash(file:*)",
            "Bash(which:*)",
            "Bash(date:*)",
            "Bash(gh:*)",
            "Bash(jq:*)",
            "Bash(direnv:*)",
            "Bash(uv:*)",
            "Bash(uvr:*)",
            "Bash(tmux capture-pane *)"
        ],
        "deny": [
            "Bash(rm -r*)",
            "Bash(rm -fr*)",
            "Bash(rm -R*)",
            "Bash(git push --force*)",
            "Bash(git push -f*)",
            "Bash(git reset --hard*)",
            "Bash(git clean -f*)",
            "Bash(gh repo delete*)",
            "Bash(gh auth logout*)",
            "Bash(sudo *)",
            "Bash(brew uninstall*)",
            "Bash(brew remove*)",
            "Bash(pip install*)",
            "Bash(pip uninstall*)",
            "Bash(pip3 install*)",
            "Bash(pip3 uninstall*)",
            "Bash(uv pip install*)",
            "Bash(uv add*)",
            "Bash(docker rm*)",
            "Bash(docker rmi*)",
            "Bash(docker system prune*)",
            "Bash(kubectl delete*)",
            "Bash(terraform apply*)",
            "Bash(terraform destroy*)"
        ],
        "defaultMode": "default",
        "disableAutoMode": "disable"
    },
    "model": "opusplan",
    "hooks": {
        "UserPromptSubmit": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash $HOME/.claude/hooks/surface-behavioral-rules.sh"
                    }
                ]
            },
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash $HOME/.claude/hooks/maintenance-check.sh"
                    }
                ]
            },
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash $HOME/.claude/hooks/ensure-repo-hooks.sh"
                    }
                ]
            },
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash $HOME/.claude/hooks/load-global-memory.sh"
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash $HOME/.claude/hooks/post-edit-lint.sh"
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Write|Edit|MultiEdit|NotebookEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash $HOME/.claude/hooks/block-em-dash.sh"
                    },
                    {
                        "type": "command",
                        "command": "bash $HOME/.claude/hooks/block-edit-on-main.sh"
                    }
                ]
            },
            {
                "matcher": "Write|Edit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash $HOME/.claude/hooks/block-sensitive-writes.sh"
                    }
                ]
            },
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash $HOME/.claude/hooks/block-destructive-commands.sh"
                    },
                    {
                        "type": "command",
                        "command": "bash $HOME/.claude/hooks/prefer-jq.sh"
                    }
                ]
            },
            {
                "matcher": "Agent|WebFetch",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash $HOME/.claude/hooks/cost-guard.sh"
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash $HOME/.claude/hooks/stop-hook-git-check.sh"
                    }
                ]
            }
        ],
        "PreCompact": [
            {
                "matcher": "*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash $HOME/.claude/hooks/pre-compact.sh"
                    }
                ]
            }
        ],
        "PostCompact": [
            {
                "matcher": "*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash $HOME/.claude/hooks/post-compact.sh"
                    }
                ]
            }
        ]
    },
    "statusLine": {
        "type": "command",
        "command": "bash $HOME/.claude/scripts/statusline-command.sh"
    },
    "enabledPlugins": {
        "frontend-design@claude-plugins-official": true,
        "anaiis-review@anaiis-plugins": true,
        "anaiis-git@anaiis-plugins": true,
        "anaiis-data@anaiis-plugins": true,
        "anaiis-writing@anaiis-plugins": true,
        "anaiis-meta@anaiis-plugins": true
    },
    "extraKnownMarketplaces": {
        "anaiis-plugins": {
            "source": {
                "source": "github",
                "repo": "datasci-iopsy/anaiis-plugins"
            }
        },
        "dbt-agent-marketplace": {
            "source": {
                "source": "github",
                "repo": "dbt-labs/dbt-agent-skills"
            }
        }
    },
    "effortLevel": "medium",
    "awaySummaryEnabled": true,
    "skipDangerousModePermissionPrompt": true,
    "autoCompactEnabled": true
}
