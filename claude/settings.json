{
    "env": {
        "GIT_AUTHOR_NAME": "datasci-iopsy",
        "GIT_COMMITTER_NAME": "datasci-iopsy"
    },
    "attribution": {
        "commit": "",
        "pr": ""
    },
    "includeGitInstructions": false,
    "permissions": {
        "allow": [
            "Read",
            "Read(/var/folders/*/*/T/coderabbit-instructions-*.txt)",
            "WebFetch(domain:docs.coderabbit.ai)",
            "WebSearch",
            "Bash(git:*)",
            "Bash(git -C *)",
            "Bash(python:*)",
            "Bash(python3:*)",
            "Bash(ls:*)",
            "Bash(cd:*)",
            "Bash(tree:*)",
            "Bash(cat:*)",
            "Bash(wc:*)",
            "Bash(diff:*)",
            "Bash(sort:*)",
            "Bash(uniq:*)",
            "Bash(cut:*)",
            "Bash(file:*)",
            "Bash(which:*)",
            "Bash(date:*)",
            "Bash(make:*)",
            "Bash(gh:*)",
            "Bash(jq:*)",
            "Bash(duckdb:*)",
            "Bash(textutil:*)",
            "Bash(bq show *)",
            "Bash(bq ls *)",
            "Bash(bq ls)",
            "Bash(bq query *)",
            "Bash(bq head *)",
            "Bash(bq version)",
            "Bash(gcloud auth list)",
            "Bash(gcloud config *)",
            "Bash(gcloud projects list *)",
            "Bash(gcloud projects describe *)",
            "Bash(gcloud * list *)",
            "Bash(gcloud * describe *)",
            "Bash(graphify:*)",
            "Bash(uv:*)",
            "Bash(ALLOW_LOCK_COMMIT=1 git commit*)"
        ],
        "defaultMode": "default",
        "disableAutoMode": "disable"
    },
    "model": "opusplan",
    "hooks": {
        "UserPromptSubmit": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash $HOME/.claude/hooks/maintenance-check.sh"
                    }
                ]
            },
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash $HOME/.claude/hooks/coderabbit-triage.sh"
                    }
                ]
            },
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash $HOME/.claude/hooks/ensure-repo-hooks.sh"
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash $HOME/.claude/hooks/post-edit-lint.sh"
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Write|Edit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "FILE=$(jq -r '.tool_input.file_path // empty'); case \"$FILE\" in *.lock|*.env|*.env.*|*credentials*|*secret*|*.pem|*.key) echo 'BLOCK: Refusing write to sensitive file: '\"$FILE\"; exit 2;; esac; exit 0"
                    }
                ]
            },
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "CMD=$(jq -r '.tool_input.command // empty'); if echo \"$CMD\" | grep -qE '^bq\\s+rm\\b'; then echo 'BLOCK: bq rm is destructive. Run this manually in terminal.' >&2; exit 2; fi; if echo \"$CMD\" | grep -qE '^gcloud\\s.*(delete|destroy|remove-iam-policy|set-iam-policy|disable|reset-windows-password)'; then echo 'BLOCK: Destructive gcloud command detected. Run this manually in terminal.' >&2; exit 2; fi; if echo \"$CMD\" | grep -qE '^uv\\s+(cache\\s+(clean|prune)|publish|tool\\s+uninstall|pip\\s+uninstall)'; then echo 'BLOCK: Destructive uv command detected. Run this manually in terminal.' >&2; exit 2; fi; exit 0"
                    },
                    {
                        "type": "command",
                        "command": "bash $HOME/.claude/hooks/prefer-jq.sh"
                    }
                ]
            },
            {
                "matcher": "Agent|WebFetch",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash $HOME/.claude/hooks/cost-guard.sh"
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash $HOME/.claude/hooks/stop-hook-git-check.sh"
                    }
                ]
            }
        ]
    },
    "statusLine": {
        "type": "command",
        "command": "bash $HOME/.claude/scripts/statusline-command.sh"
    },
    "effortLevel": "medium",
    "awaySummaryEnabled": true
}