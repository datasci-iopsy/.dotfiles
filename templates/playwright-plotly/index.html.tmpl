<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{TITLE}}</title>
    <script src="https://cdn.plot.ly/plotly-2.32.0.min.js"></script>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            margin: 0;
            padding: 1.5rem;
            background: #f9f9f9;
        }
        h1 {
            font-size: 1.2rem;
            font-weight: 600;
            margin-bottom: 1rem;
            color: #1a1a1a;
        }
        #chart {
            width: 100%;
            height: 500px;
        }
    </style>
</head>
<body>
    <h1>{{TITLE}}</h1>
    <div id="chart"></div>
    <script>
        const figJson = {{FIGURE_JSON}};
        Plotly.newPlot("chart", figJson.data, figJson.layout, { responsive: true }).then(() => {
            document.getElementById("chart").setAttribute("data-plotly-rendered", "true");
        });
    </script>
</body>
</html>
