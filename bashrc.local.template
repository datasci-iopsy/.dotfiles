# ~/.bashrc.local — Machine-local overrides (not tracked in git)
#
# Sourced last by ~/.bashrc. Values here override shared.bash.
# Never commit this file — it holds machine-specific secrets and paths.
#
# Setup: copy this file to ~/.bashrc.local, then ensure ~/.bashrc contains:
#   [ -f ~/.bashrc.local ] && . ~/.bashrc.local

# ── Shared preferences (tracked, syncs across machines via git pull) ──────────
if [ -f "$HOME/.dotfiles/bash/shared.bash" ]; then
    . "$HOME/.dotfiles/bash/shared.bash"
fi

# ── Machine-local overrides ───────────────────────────────────────────────────

# GCP project (machine-specific — set per machine)
# export GOOGLE_CLOUD_PROJECT="your-project-id"

# Additional PATH entries specific to this machine
# export PATH="$PATH:/custom/path"

# Machine-specific tool config
# export SOME_API_KEY="..."
