# OS
.DS_Store

# Never commit machine-specific or sensitive files
*.local
*.env
*.env.*
!.env.example
*credentials*
*secret*
*.pem
*.key

# Machine-local Claude overrides (generated by install.sh from *.template files)
.claude/
claude/settings.local.json
claude/CLAUDE.local.md

# vscode
.vscode/

# Vendored Python environments (machine-local, reproducible from submodule)
vendor/graphify-venv/

# Homebrew bundle lockfile (regenerated on every install; not pinned)
Brewfile.lock.json

# Misc
_archive