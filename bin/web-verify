#!/usr/bin/env bash
# web-verify: serve the current directory and run Playwright smoke tests.
#
# Commands:
#   web-verify run              Serve + test (default)
#   web-verify run --headed     Same, with visible browser
#   web-verify init             Copy playwright-static template into cwd
#   web-verify install          Install @playwright/test and chromium browser
#   web-verify screenshot       Run and save screenshot to artifacts/
#   web-verify --help           Print this message

set -euo pipefail

TEMPLATES="${HOME}/.dotfiles/templates"
DEFAULT_PORT=8080
SELECTOR="${TEST_SELECTOR:-body}"

usage() {
    sed -n 's/^# //p' "$0"
    exit 0
}

find_free_port() {
    local port="${DEFAULT_PORT}"
    while lsof -iTCP:"${port}" -sTCP:LISTEN -t >/dev/null 2>&1; do
        port=$((port + 1))
    done
    echo "${port}"
}

wait_for_port() {
    local port="${1}"
    local attempts=0
    until curl -s "http://localhost:${port}" >/dev/null 2>&1; do
        sleep 0.2
        attempts=$((attempts + 1))
        if [[ ${attempts} -ge 25 ]]; then
            echo "ERROR: server did not bind on port ${port} after 5 seconds" >&2
            return 1
        fi
    done
}

cmd_init() {
    local tmpl="${TEMPLATES}/playwright-static"
    if [[ ! -d "${tmpl}" ]]; then
        echo "ERROR: template not found at ${tmpl}" >&2
        exit 1
    fi
    if [[ -f playwright.config.ts ]]; then
        echo "playwright.config.ts already exists; skipping init" >&2
        exit 0
    fi
    cp -r "${tmpl}/." .
    echo "scaffolded playwright-static template into $(pwd)"
    echo "run: web-verify install"
}

cmd_install() {
    npm install --save-dev @playwright/test
    npx playwright install chromium
    echo "done: @playwright/test and chromium installed"
}

cmd_run() {
    local extra_args=("${@}")
    local port
    port=$(find_free_port)

    python3 -m http.server "${port}" --bind 127.0.0.1 >/dev/null 2>&1 &
    local server_pid="${!}"
    trap "kill ${server_pid} 2>/dev/null || true" EXIT

    wait_for_port "${port}"

    mkdir -p test-results artifacts

    BASE_URL="http://localhost:${port}" TEST_SELECTOR="${SELECTOR}" \
        npx playwright test "${extra_args[@]}"

    local exit_code="${?}"
    kill "${server_pid}" 2>/dev/null || true
    exit "${exit_code}"
}

cmd_screenshot() {
    local port
    port=$(find_free_port)
    local slug
    slug=$(basename "$(pwd)")
    local out="artifacts/screenshot-${slug}.png"

    python3 -m http.server "${port}" --bind 127.0.0.1 >/dev/null 2>&1 &
    local server_pid="${!}"
    trap "kill ${server_pid} 2>/dev/null || true" EXIT

    wait_for_port "${port}"
    mkdir -p artifacts

    BASE_URL="http://localhost:${port}" \
        npx playwright screenshot \
        --browser chromium \
        "http://localhost:${port}" \
        "${out}"

    kill "${server_pid}" 2>/dev/null || true
    echo "screenshot saved: ${out}"
}

# Parse command
cmd="${1:-run}"
shift || true

case "${cmd}" in
    run) cmd_run "${@}" ;;
    init) cmd_init ;;
    install) cmd_install ;;
    screenshot) cmd_screenshot ;;
    --help | -h | help) usage ;;
    *)
        echo "Unknown command: ${cmd}" >&2
        usage
        ;;
esac
