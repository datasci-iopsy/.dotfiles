#!/usr/bin/env bash
# bin/claude — shell-agnostic CodeRabbit batch interceptor.
#
# Why this exists: CodeRabbit's "fix all" batches are passed as a single
# argument followed by a trailing `&& rm <tmpfile>` that removes the source
# before Claude can read it. Intercepting at the shell level (before claude
# starts) is the only place we can capture the batch contents safely. A
# Claude PreToolUse hook can't help here — by the time hooks fire, claude
# is already past startup.
#
# Install: add this directory to PATH ahead of the real claude:
#     export PATH="$HOME/.dotfiles/bin:$PATH"
# Works in bash, zsh, fish, or any POSIX shell. No `source` required.
#
# Behavior:
#   - If the first arg contains >=2 "Verify each finding against the current
#     code" lines, stage to ~/.claude/coderabbit-staged-batch.md and exec
#     real claude WITHOUT the batch arg (so the user can run /coderabbit-fix
#     interactively).
#   - Otherwise, exec real claude with all args, unchanged.

set -eu

# ── Locate the real claude (skip our own directory in PATH) ───────────────
self_dir="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
real_claude=""
IFS=:
for d in $PATH; do
    case "$d" in
        "" | "$self_dir") continue ;;
    esac
    if [ -x "$d/claude" ] && [ ! "$(cd "$d" && pwd)" = "$self_dir" ]; then
        real_claude="$d/claude"
        break
    fi
done
unset IFS

if [ -z "$real_claude" ]; then
    echo "bin/claude: real 'claude' not found in PATH (after skipping $self_dir)" >&2
    exit 127
fi

# ── CodeRabbit batch detection ────────────────────────────────────────────
arg="${1:-}"
count=0
if [ -n "$arg" ]; then
    count=$(printf '%s' "$arg" | grep -c 'Verify each finding against the current code' 2>/dev/null || true)
fi

if [ "${count:-0}" -ge 2 ]; then
    mkdir -p "$HOME/.claude"
    {
        printf '# CodeRabbit Staged Batch\n'
        printf '# Staged: %s\n' "$(date '+%Y-%m-%d %H:%M')"
        printf '# Findings: %s\n' "$count"
        printf '\n'
        printf '%s\n' "$arg"
    } > "$HOME/.claude/coderabbit-staged-batch.md"
    printf '[CodeRabbit] %s finding(s) staged to ~/.claude/coderabbit-staged-batch.md\n' "$count"
    printf '[CodeRabbit] Run /coderabbit-fix inside Claude to process through triage.\n'
    shift
fi

exec "$real_claude" "$@"
